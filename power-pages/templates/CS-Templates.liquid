{% comment %}
  Elections Canada – Electronic Signature Service (ESIGN)
  All Templates Web Template  (/all-templates)
  NO inline onclick/onX handlers — all listeners attached via addEventListener
  to satisfy Power Pages CSP (script-src nonce injection only covers <script> blocks).
  Snippet namespace: ESIGN/*
{% endcomment %}

{% if user %}

<main class="pepp-app" property="mainContentOfPage" resource="#wb-main" typeof="WebPageElement">
  <div class="container mrgn-tp-lg mrgn-bttm-lg">

    <!-- Page header -->
    <section class="row mrgn-bttm-md">
      <div class="col-sm-8">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb" style="background:none;padding:0;margin-bottom:8px;font-size:13px;">
            <li><a href="/">{{ snippets['ESIGN/BC/HOME'] | default: 'Home' }}</a></li>
            <li class="active">{{ snippets['ESIGN/TEMPLATES/TITLE'] | default: 'Available Templates' }}</li>
          </ol>
        </nav>
        <h1 class="h2 mrgn-tp-0">
          <span class="fa fa-files-o mrgn-rght-sm" style="color:#26374A;"></span>
          {{ snippets['ESIGN/TEMPLATES/TITLE'] | default: 'Available Templates' }}
        </h1>
        <p class="text-muted">{{ snippets['ESIGN/TEMPLATES/DESC'] | default: 'Browse approved signature templates. Click <strong>Use</strong> to send a new envelope, or <strong>Download</strong> to save the source document.' }}</p>
      </div>
      <div class="col-sm-4 text-right" style="padding-top:28px;">
        <!-- Triggers WET lightbox / Bootstrap 3 modal — no inline handler -->
        <a href="/templates/edit-template"
           class="btn btn-default"
           style="border-color:#26374A;color:#26374A;border-radius:0;font-weight:600;">
          <span class="fa fa-plus mrgn-rght-sm"></span>
          {{ snippets['ESIGN/TEMPLATES/CREATE_BTN'] | default: 'Create Template' }}
        </a>
      </div>
    </section>

    <!-- Search / filter bar: search left, category dropdown right-aligned -->
    <section class="row mrgn-bttm-md" style="display:flex;align-items:center;flex-wrap:wrap;gap:0;">
      <div class="col-md-6 col-sm-8">
        <div class="input-group">
          <input type="text" id="tpl-search" class="form-control"
                 placeholder="{{ snippets['ESIGN/TEMPLATES/SEARCH_PH'] | default: 'Search templates...' }}"
                 style="border-radius:0;border-color:#ccc;">
          <span class="input-group-btn">
            <button id="tpl-search-btn" class="btn btn-default" type="button"
                    style="border-radius:0;background:#26374A;color:#fff;border-color:#26374A;">
              <span class="fa fa-search"></span>
              <span class="wb-inv">Search</span>
            </button>
          </span>
        </div>
      </div>
      <!-- col-md-3 col-md-offset-3 pushes the dropdown to the far right on md+ screens -->
      <div class="col-md-3 col-md-offset-3 col-sm-4">
        <select id="tpl-category" class="form-control" style="border-radius:0;border-color:#ccc;">
          <option value="">{{ snippets['ESIGN/TEMPLATES/ALL_CATS'] | default: 'All Categories' }}</option>
        </select>
      </div>
    </section>

    <!-- Templates table panel -->
    <section class="row">
      <div class="col-md-12">
        <div class="panel panel-default">
          <div class="panel-heading" style="background:#26374A;">
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <h2 class="panel-title" style="font-weight:600;color:#fff;font-size:15px;">
                <span class="fa fa-table mrgn-rght-sm"></span>
                {{ snippets['ESIGN/TEMPLATES/TABLE_HEADING'] | default: 'Signature Templates' }}
              </h2>
<span id="tpl-count"
                    style="background:rgba(0,0,0,0.35);color:#fff;font-size:12px;font-weight:600;padding:4px 12px;border-radius:3px;display:inline-block;white-space:nowrap;"></span>
            </div>
          </div>

          <div id="tpl-loading" class="panel-body text-center" style="padding:40px;">
            <span class="fa fa-spinner fa-spin" style="font-size:2rem;color:#26374A;display:block;margin-bottom:10px;"></span>
            <p class="text-muted mrgn-bttm-0">{{ snippets['ESIGN/TEMPLATES/LOADING'] | default: 'Loading templates...' }}</p>
          </div>

          <div id="tpl-error" class="panel-body" style="display:none;">
            <div class="alert alert-danger mrgn-bttm-0" role="alert">
              <span class="fa fa-exclamation-triangle mrgn-rght-sm"></span>
              <strong>{{ snippets['ESIGN/TEMPLATES/ERR_TITLE'] | default: 'Unable to load templates.' }}</strong>
              {{ snippets['ESIGN/TEMPLATES/ERR_DESC'] | default: 'Please refresh the page or contact support.' }}
            <br><small id="tpl-error-detail" class="text-muted"></small>
            </div>
          </div>

          <div id="tpl-table-wrap" class="panel-body" style="display:none;padding:0;">
            <div class="table-responsive">
              <table class="table table-hover mrgn-bttm-0" id="tpl-table">
                <thead>
                  <tr style="background:#f5f5f5;">
                    <th style="width:38%;cursor:pointer;" data-sort="cs_name">{{ snippets['ESIGN/TEMPLATES/COL_NAME'] | default: 'Template Name' }} <span class="sort-icon"></span></th>
                    <th style="width:18%;cursor:pointer;" class="tpl-hide-mobile" data-sort="cs_category">{{ snippets['ESIGN/TEMPLATES/COL_CAT'] | default: 'Category' }} <span class="sort-icon"></span></th>
                    <th style="width:15%;cursor:pointer;" class="tpl-hide-mobile" data-sort="modifiedon">{{ snippets['ESIGN/TEMPLATES/COL_MODIFIED'] | default: 'Last Modified' }} <span class="sort-icon"></span></th>
                    <th style="width:11%;" class="text-center tpl-hide-mobile">{{ snippets['ESIGN/TEMPLATES/COL_VERSION'] | default: 'Version' }}</th>
                    <th style="width:18%;" class="text-center">{{ snippets['ESIGN/TEMPLATES/COL_ACTIONS'] | default: 'Actions' }}</th>
                  </tr>
                </thead>
                <tbody id="tpl-tbody"></tbody>
              </table>
            </div>
          </div>

          <div id="tpl-empty" class="panel-body text-center" style="display:none;padding:50px 20px;">
            <span class="fa fa-inbox" style="font-size:3rem;color:#ccc;display:block;margin-bottom:15px;"></span>
            <h3 class="h4" style="color:#555;">{{ snippets['ESIGN/TEMPLATES/EMPTY_TITLE'] | default: 'No templates found' }}</h3>
            <p class="text-muted">{{ snippets['ESIGN/TEMPLATES/EMPTY_DESC'] | default: 'No templates match your search. Try adjusting your filters or create a new template.' }}</p>
            <a href="/templates/edit-template"
               class="btn btn-default"
               style="border-color:#26374A;color:#26374A;border-radius:0;margin-top:10px;">
              <span class="fa fa-plus mrgn-rght-sm"></span>
              {{ snippets['ESIGN/TEMPLATES/CREATE_BTN'] | default: 'Create Template' }}
            </a>
          </div>

          <div id="tpl-pagination" class="panel-footer"
               style="display:none;background:#f9f9f9;border-top:1px solid #ddd;padding:10px 15px;">
            <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
              <span id="tpl-page-info" class="small text-muted"></span>
              <div>
                <button id="tpl-prev" class="btn btn-xs btn-default" style="border-radius:0;" disabled>
                  <span class="fa fa-chevron-left mrgn-rght-xs"></span>
                  {{ snippets['ESIGN/TEMPLATES/PREV'] | default: 'Previous' }}
                </button>
                <button id="tpl-next" class="btn btn-xs btn-default" style="border-radius:0;margin-left:4px;" disabled>
                  {{ snippets['ESIGN/TEMPLATES/NEXT'] | default: 'Next' }}
                  <span class="fa fa-chevron-right mrgn-lft-xs"></span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>
</main>


<script>
(function () {
  'use strict';

  /* ── Config ──────────────────────────────────────────────────────────── */
  var PAGE_SIZE  = 10;
  var API_BASE   = '/_api/cs_templates';
  var USE_URL    = '/new-envelope';
  var PARAM_TPL  = 'templateId';

  /* ── State ───────────────────────────────────────────────────────────── */
  var allRecords  = [];
  var filtered    = [];
  var currentPage = 1;
  var signerCount = 0;
  var sortCol     = 'modifiedon';
  var sortDir     = 'desc';

  /* ── DOM refs (all resolved after DOMContentLoaded) ──────────────────── */
  var elLoading, elError, elTableWrap, elEmpty, elTbody,
      elCount, elPagWrap, elPageInfo, elPrev, elNext,
      elSearch, elCategory, elSignersList,
      elName, elDesc, elCatInput, elFileInput, elPreview,
      elCreateSuccess, elCreateError, elCreateErrorMsg,
      elSubmitBtn;

  /* ── Helpers ─────────────────────────────────────────────────────────── */
  function show(el)  { el.style.display = ''; }
  function hide(el)  { el.style.display = 'none'; }

  function esc(s) {
    return String(s || '')
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function fmtDate(iso) {
    if (!iso) return '--';
    return new Date(iso).toLocaleDateString('en-CA');
  }

  var STATUS_STYLE = {
    'Active':   'background:#1a5336;color:#fff;',
    'Inactive': 'background:#767676;color:#fff;',
    'Archived': 'background:#d83b01;color:#fff;'
  };

  /* ── Category dropdown ───────────────────────────────────────────────── */
  function buildCategoryFilter(records) {
    var seen = {};
    records.forEach(function (r) {
      var cat = r.cs_category || '';
      if (cat && !seen[cat]) {
        seen[cat] = true;
        var opt = document.createElement('option');
        opt.value       = cat;
        opt.textContent = cat;
        elCategory.appendChild(opt);
      }
    });
  }

  /* ── Sort ────────────────────────────────────────────────────────────── */
  function sortFiltered() {
    filtered.sort(function (a, b) {
      var av = (a[sortCol] || '').toString().toLowerCase();
      var bv = (b[sortCol] || '').toString().toLowerCase();
      if (av < bv) return sortDir === 'asc' ? -1 : 1;
      if (av > bv) return sortDir === 'asc' ? 1 : -1;
      return 0;
    });
  }

  function toggleSort(col) {
    if (sortCol === col) { sortDir = sortDir === 'asc' ? 'desc' : 'asc'; }
    else { sortCol = col; sortDir = col === 'modifiedon' ? 'desc' : 'asc'; }
    currentPage = 1;
    updateSortIcons();
    sortFiltered();
    renderPage();
  }

  function updateSortIcons() {
    document.querySelectorAll('#tpl-table-wrap th[data-sort]').forEach(function (th) {
      var icon = th.querySelector('.sort-icon');
      if (!icon) return;
      if (th.getAttribute('data-sort') === sortCol) {
        icon.textContent = sortDir === 'asc' ? ' \u25B2' : ' \u25BC';
        icon.style.opacity = '1';
      } else {
        icon.textContent = ' \u25B4';
        icon.style.opacity = '0.3';
      }
    });
  }

  /* ── Render current page ─────────────────────────────────────────────── */
  function renderPage() {
    var total = filtered.length;
    var start = (currentPage - 1) * PAGE_SIZE;
    var end   = Math.min(start + PAGE_SIZE, total);
    var page  = filtered.slice(start, end);

    elTbody.innerHTML = '';

    if (total === 0) {
      hide(elTableWrap);
      hide(elPagWrap);
      show(elEmpty);
      elCount.textContent = '0 templates';
      return;
    }

    hide(elEmpty);
    show(elTableWrap);

    page.forEach(function (tpl) {
      var isActive   = tpl.cs_isactive !== false;
      var status     = isActive ? 'Active' : 'Inactive';
      var badge      = STATUS_STYLE[status] || STATUS_STYLE['Inactive'];
      var useHref    = USE_URL + '?' + PARAM_TPL + '=' + esc(tpl.cs_templateid);
      var hasJson    = !!tpl.cs_templatejson;

      /* Download: fetch the template's pdfBase64 from cs_templatejson and
         trigger a client-side blob download. The button calls downloadTplPdf(id). */
      var dlBtn = hasJson
        ? '<button type="button" class="btn btn-xs btn-default tpl-dl-btn" ' +
            'style="border-radius:0;" title="Download PDF" ' +
            'data-id="' + esc(tpl.cs_templateid) + '" data-name="' + esc(tpl.cs_name || 'template') + '">' +
            '<span class="fa fa-download"></span></button>'
        : '<button type="button" class="btn btn-xs btn-default" style="border-radius:0;" ' +
            'disabled title="No document attached"><span class="fa fa-download"></span></button>';

      elTbody.innerHTML +=
        '<tr>' +
          '<td>' +
            '<a href="#" class="esign-tpl-link" data-tpl-id="' + esc(tpl.cs_templateid) + '" style="color:#26374A;text-decoration:none;"><strong>' + esc(tpl.cs_name || 'Untitled') + '</strong></a>' +
            (tpl.cs_description ? '<br><span class="small text-muted">' + esc(tpl.cs_description) + '</span>' : '') +
          '</td>' +
          '<td class="tpl-hide-mobile">' + esc(tpl.cs_category || '--') + '</td>' +
          '<td class="tpl-hide-mobile">' + fmtDate(tpl.modifiedon) + '</td>' +
          '<td class="text-center tpl-hide-mobile">' +
            '<span style="display:inline-block;' + badge + 'padding:2px 8px;border-radius:3px;font-size:11px;">' +
              esc(status) +
            '</span>' +
          '</td>' +
          '<td class="text-center" style="white-space:nowrap;">' +
            /* Desktop: inline buttons */
            '<span class="tpl-actions-desktop">' +
              '<a href="/templates/edit-template/?id=' + esc(tpl.cs_templateid) + '" class="btn btn-xs btn-default" ' +
                 'style="border-color:#005a70;color:#005a70;border-radius:0;margin-right:4px;" ' +
                 'title="Edit template"><span class="fa fa-pencil mrgn-rght-xs"></span>Edit</a>' +
              '<a href="/envelopes/edit-envelope/?templateId=' + esc(tpl.cs_templateid) + '" class="btn btn-xs btn-default" ' +
                 'style="border-color:#26374A;color:#26374A;border-radius:0;margin-right:4px;" ' +
                 'title="Create an envelope using this template"><span class="fa fa-paper-plane mrgn-rght-xs"></span>Use</a>' +
              dlBtn +
            '</span>' +
            /* Mobile: action menu (pure JS toggle) */
            '<span class="tpl-actions-mobile" style="position:relative;">' +
              '<button type="button" class="btn btn-xs btn-default esign-action-toggle" style="border-radius:0;">' +
                '<span class="fa fa-ellipsis-v"></span>' +
              '</button>' +
              '<div class="esign-action-menu">' +
                '<a href="/templates/edit-template/?id=' + esc(tpl.cs_templateid) + '"><span class="fa fa-pencil mrgn-rght-sm"></span>Edit</a>' +
                '<a href="/envelopes/edit-envelope/?templateId=' + esc(tpl.cs_templateid) + '"><span class="fa fa-paper-plane mrgn-rght-sm"></span>Use</a>' +
                (hasJson
                  ? '<a href="#" class="tpl-dl-btn-m" data-id="' + esc(tpl.cs_templateid) + '" data-name="' + esc(tpl.cs_name || 'template') + '"><span class="fa fa-download mrgn-rght-sm"></span>Download</a>'
                  : '') +
              '</div>' +
            '</span>' +
          '</td>' +
        '</tr>';
    });

    /* Wire mobile action toggles (pure JS) */
    elTbody.querySelectorAll('.esign-action-toggle').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var menu = this.nextElementSibling;
        document.querySelectorAll('.esign-action-menu.open').forEach(function (m) {
          if (m !== menu) { m.classList.remove('open'); m.classList.remove('flip-up'); }
        });
        menu.classList.remove('flip-up');
        menu.classList.toggle('open');
        if (menu.classList.contains('open')) {
          var rect = menu.getBoundingClientRect();
          if (rect.bottom > window.innerHeight - 10) {
            menu.classList.add('flip-up');
          }
        }
      });
    });
    document.addEventListener('click', function () {
      document.querySelectorAll('.esign-action-menu.open').forEach(function (m) { m.classList.remove('open'); m.classList.remove('flip-up'); });
    });

    /* Wire download buttons — desktop */
    elTbody.querySelectorAll('.tpl-dl-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id   = this.getAttribute('data-id');
        var name = this.getAttribute('data-name');
        downloadTplPdf(id, name, this);
      });
    });
    /* Wire download buttons — mobile dropdown */
    elTbody.querySelectorAll('.tpl-dl-btn-m').forEach(function (a) {
      a.addEventListener('click', function (e) {
        e.preventDefault();
        downloadTplPdf(this.getAttribute('data-id'), this.getAttribute('data-name'), this);
      });
    });
    /* Wire template name links → show detail modal */
    elTbody.querySelectorAll('.esign-tpl-link').forEach(function (a) {
      a.addEventListener('click', function (e) {
        e.preventDefault();
        showTemplateModal(this.getAttribute('data-tpl-id'));
      });
    });

    elCount.textContent = total + (total === 1 ? ' template' : ' templates');
    var totalPages = Math.ceil(total / PAGE_SIZE);
    elPageInfo.textContent = 'Showing ' + (start + 1) + '–' + end + ' of ' + total;
    elPrev.disabled = (currentPage === 1);
    elNext.disabled = (currentPage >= totalPages);
    if (total > PAGE_SIZE) { show(elPagWrap); } else { hide(elPagWrap); }
  }

  /* ── Filter ──────────────────────────────────────────────────────────── */
  function applyFilters() {
    var q   = (elSearch.value || '').toLowerCase().trim();
    var cat = elCategory.value;
    currentPage = 1;
    filtered = allRecords.filter(function (r) {
      var nm = !q ||
        (r.cs_name        || '').toLowerCase().indexOf(q) >= 0 ||
        (r.cs_description || '').toLowerCase().indexOf(q) >= 0 ||
        (r.cs_category    || '').toLowerCase().indexOf(q) >= 0 ||
        false;
      var cm = !cat || (r.cs_category || '') === cat;
      return nm && cm;
    });
    sortFiltered();
    renderPage();
  }

  /* ── Portal fetch helpers (Power Pages Bootstrap 5) ────────────────────
     Power Pages Web API lives at /_api/<entitysetname>
     - Do NOT send OData-Version headers — the portal proxy rejects them
     - GET requests need only Accept: application/json
     - POST/PATCH need the __RequestVerificationToken from the page's
       hidden input (Power Pages injects this on every authenticated page)
     - On error, parse the JSON body so we can surface the OData error code  */

  function safeAjax(ajaxOptions) {
    var deferred = $.Deferred();
    shell.getTokenDeferred().done(function (token) {
      if (!ajaxOptions.headers) { ajaxOptions.headers = {}; }
      ajaxOptions.headers['__RequestVerificationToken'] = token;
      $.ajax(ajaxOptions)
        .done(function (data, status, xhr) { deferred.resolve(data, status, xhr); })
        .fail(function (xhr, status, err)  { deferred.reject(xhr, status, err); });
    }).fail(function () { deferred.rejectWith(this, arguments); });
    return deferred.promise();
  }

    function portalGet(url) {
    return fetch(url, {
      method: 'GET', credentials: 'same-origin',
      headers: { 'Accept': 'application/json' }
    }).then(function (r) {
      if (!r.ok) { return parseErrorBody(r).then(function (e) { throw e; }); }
      return r.json();
    });
  }

  function portalPost(url, payload) {
    return new Promise(function (resolve, reject) {
      safeAjax({
        type: 'POST', url: url, contentType: 'application/json',
        data: JSON.stringify(payload), headers: { 'Accept': 'application/json' }
      })
      .done(function (data, status, xhr) { resolve(xhr.status === 204 ? null : data); })
      .fail(function (xhr) { reject(new Error('HTTP ' + xhr.status + ': ' + xhr.responseText)); });
    });
  }

  /* ── Load templates ──────────────────────────────────────────────────── */
  /* Column list — remove any that don't exist in your Dataverse table yet  */
  /* Columns confirmed from /_api/cs_templates?$top=1 response */
  var SELECT_COLS = [
    'cs_templateid',
    'cs_name',
    'cs_description',
    'cs_category',
    'cs_isactive',
    'cs_templatejson',
    'statecode',
    'statuscode',
    'modifiedon',
    'createdon',
  ].join(',');

  function loadTemplates() {
    hide(elError);
    hide(elTableWrap);
    hide(elEmpty);
    show(elLoading);

    /* Phase 1 — minimal probe: just $top=1, no $select, no $orderby.
       Failure modes:
         400 / 9004010A → Table Permission missing or portal cache stale
         403            → Web Role not assigned to Table Permission
         404            → Entity set name wrong (not "cs_templates")
         200            → table reachable; Phase 2 runs full query          */
    portalGet(API_BASE + '?$top=1')
      .then(function () {
        /* Phase 2 — full query with $select */
        return portalGet(
          API_BASE + '?$orderby=cs_name asc&$select=' + SELECT_COLS
        );
      })
      .then(function (data) {
        hide(elLoading);
        if (!data || !data.value) { show(elError); return; }
        allRecords = data.value;
        filtered   = allRecords.slice();
        buildCategoryFilter(allRecords);
        sortFiltered();
        renderPage();
      })
      .catch(function (err) {
        console.error('ESIGN loadTemplates:', err.message);
        hide(elLoading);
        var detail = document.getElementById('tpl-error-detail');
        if (detail) {
          var msg = err.message || '';
          var hint = '';
          if (msg.indexOf('9004010A') >= 0 || msg.indexOf('400') >= 0) {
            hint =
              'Site Settings are present — the likely causes are: ' +
              '(1) Portal cache not cleared after adding Site Settings ' +
              '— go to /_services/about and click Restart, or use PAC CLI: ' +
              'pac paportal clear-cache; ' +
              '(2) Table Permission record missing — in Portal Management, ' +
              'create a Table Permission for cs_template with scope=Global, ' +
              'privilege=Read+Write, and assign it to the Authenticated Users web role. ';
          } else if (msg.indexOf('403') >= 0) {
            hint = 'Access denied — Table Permission exists but is not linked to the correct Web Role. ' +
                   'Open the Table Permission record and add Authenticated Users to Web Roles. ';
          } else if (msg.indexOf('404') >= 0) {
            hint = 'Table not found — verify the Dataverse table entity set name. ' +
                   'Try opening /_api/ in browser to list available entity sets. ';
          } else if (msg.indexOf('SELECT') >= 0 || msg.indexOf('column') >= 0) {
            hint = 'A column in the $select list does not exist on the table. ' +
                   'Remove custom columns from SELECT_COLS one by one to isolate. ';
          }
          detail.innerHTML = hint +
            '<br><code style="font-size:11px;word-break:break-all;">' + msg + '</code>';
        }
        show(elError);
      });
  }





  /* ── Download template PDF ──────────────────────────────────────────── */
  function downloadTplPdf(templateId, templateName, btnEl) {
    if (btnEl) { btnEl.disabled = true; btnEl.innerHTML = '<span class="fa fa-spinner fa-spin"></span>'; }

    /* Try annotation first, fall back to legacy pdfBase64 in cs_templatejson */
    $.ajax({
      type: 'GET',
      url: '/_api/annotations?$filter=_objectid_value eq ' + templateId +
           ' and subject eq \'TemplateSourcePDF\'&$select=documentbody,filename&$top=1',
      headers: { 'Accept': 'application/json' }
    })
    .done(function (noteData) {
      var b64 = null, filename = templateName || 'template';

      if (noteData && noteData.value && noteData.value.length > 0 && noteData.value[0].documentbody) {
        /* Found PDF in annotation */
        b64 = noteData.value[0].documentbody;
        filename = noteData.value[0].filename || filename;
      }

      if (b64) {
        triggerPdfDownload(b64, filename, btnEl);
      } else {
        /* Fallback: check legacy pdfBase64 in cs_templatejson */
        portalGet('/_api/cs_templates(' + templateId + ')?$select=cs_templatejson,cs_name')
          .then(function (data) {
            if (data && data.cs_templatejson) {
              try {
                var json = JSON.parse(data.cs_templatejson);
                if (json.pdfBase64) {
                  triggerPdfDownload(json.pdfBase64, json.pdfFilename || filename, btnEl);
                  return;
                }
              } catch (e) { /* parse error */ }
            }
            if (btnEl) { btnEl.disabled = false; btnEl.innerHTML = '<span class="fa fa-download"></span>'; }
            alert('No PDF document found. Open the template editor to upload one.');
          })
          .catch(function () {
            if (btnEl) { btnEl.disabled = false; btnEl.innerHTML = '<span class="fa fa-download"></span>'; }
            alert('Failed to check template for PDF.');
          });
      }
    })
    .fail(function () {
      if (btnEl) { btnEl.disabled = false; btnEl.innerHTML = '<span class="fa fa-download"></span>'; }
      alert('Failed to fetch PDF. Check table permissions for annotations.');
    });
  }

  function triggerPdfDownload(b64, filename, btnEl) {
    if (btnEl) { btnEl.disabled = false; btnEl.innerHTML = '<span class="fa fa-download"></span>'; }
    var binary = atob(b64);
    var bytes  = new Uint8Array(binary.length);
    for (var i = 0; i < binary.length; i++) { bytes[i] = binary.charCodeAt(i); }
    var blob   = new Blob([bytes], { type: 'application/pdf' });
    var url    = URL.createObjectURL(blob);
    var anchor = document.createElement('a');
    anchor.href = url;
    anchor.download = (filename || 'template') + (filename.endsWith('.pdf') ? '' : '.pdf');
    anchor.download = anchor.download.replace(/\.pdf\.pdf$/, '.pdf');
    document.body.appendChild(anchor);
    anchor.click();
    document.body.removeChild(anchor);
    setTimeout(function () { URL.revokeObjectURL(url); }, 5000);
  }

  /* ── Init ────────────────────────────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {

    /* Resolve DOM refs */
    elLoading       = document.getElementById('tpl-loading');
    elError         = document.getElementById('tpl-error');
    elTableWrap     = document.getElementById('tpl-table-wrap');
    elEmpty         = document.getElementById('tpl-empty');
    elTbody         = document.getElementById('tpl-tbody');
    elCount         = document.getElementById('tpl-count');
    elPagWrap       = document.getElementById('tpl-pagination');
    elPageInfo      = document.getElementById('tpl-page-info');
    elPrev          = document.getElementById('tpl-prev');
    elNext          = document.getElementById('tpl-next');
    elSearch        = document.getElementById('tpl-search');
    elCategory      = document.getElementById('tpl-category');

    /* Table events */
    document.getElementById('tpl-search-btn').addEventListener('click', applyFilters);
    elSearch.addEventListener('keyup', function (e) { if (e.key === 'Enter') applyFilters(); });
    elCategory.addEventListener('change', applyFilters);

    /* Column sorting */
    document.querySelectorAll('#tpl-table-wrap th[data-sort]').forEach(function (th) {
      th.addEventListener('click', function () { toggleSort(this.getAttribute('data-sort')); });
    });
    updateSortIcons();
    elPrev.addEventListener('click', function () { if (currentPage > 1) { currentPage--; renderPage(); } });
    elNext.addEventListener('click', function () {
      if (currentPage < Math.ceil(filtered.length / PAGE_SIZE)) { currentPage++; renderPage(); }
    });

    /* Close modal on overlay or X click */
    document.addEventListener('click', function (e) {
      if (e.target.id === 'esignTplModal' || e.target.classList.contains('esign-modal-close')) {
        document.getElementById('esignTplModal').style.display = 'none';
      }
    });

    /* Kick off data load */
    loadTemplates();
  });

  /* ── Template detail modal ─────────────────────────────────────────── */
  function showTemplateModal(tplId) {
    /* Find the template in allRecords (already loaded with cs_templatejson) */
    var tpl = null;
    for (var i = 0; i < allRecords.length; i++) {
      if (allRecords[i].cs_templateid === tplId) { tpl = allRecords[i]; break; }
    }
    if (!tpl) return;

    var nintexId = '';
    try {
      var json = JSON.parse(tpl.cs_templatejson || '{}');
      nintexId = json.nintexTemplateId || '';
    } catch (e) { /* ignore */ }

    var modal = document.getElementById('esignTplModal');
    var body  = document.getElementById('esignTplModalBody');
    body.innerHTML =
      '<table class="table table-condensed" style="margin:0;">' +
        '<tr><td style="font-weight:600;width:40%;padding:8px;">Template Name</td><td style="padding:8px;">' + esc(tpl.cs_name || 'Untitled') + '</td></tr>' +
        '<tr><td style="font-weight:600;padding:8px;">Description</td><td style="padding:8px;">' + esc(tpl.cs_description || '--') + '</td></tr>' +
        '<tr><td style="font-weight:600;padding:8px;">Category</td><td style="padding:8px;">' + esc(tpl.cs_category || '--') + '</td></tr>' +
        '<tr><td style="font-weight:600;padding:8px;">Nintex Template ID</td><td style="padding:8px;font-family:monospace;font-size:12px;">' + esc(nintexId || 'Not synced') + '</td></tr>' +
      '</table>' +
      '<div style="padding:12px;text-align:right;border-top:1px solid #e0e0e0;margin-top:8px;">' +
        '<a href="/templates/edit-template/?id=' + esc(tplId) + '" class="btn btn-sm btn-default" style="border-color:#005a70;color:#005a70;border-radius:0;margin-right:6px;">' +
          '<span class="fa fa-pencil mrgn-rght-xs"></span>Edit Template</a>' +
        '<a href="/envelopes/edit-envelope/?templateId=' + esc(tplId) + '" class="btn btn-sm btn-default" style="border-color:#26374A;color:#26374A;border-radius:0;">' +
          '<span class="fa fa-paper-plane mrgn-rght-xs"></span>Use Template</a>' +
      '</div>';
    document.getElementById('esignTplModalTitle').textContent = tpl.cs_name || 'Template Details';
    modal.style.display = 'flex';
  }

})();
</script>

<!-- Template Detail Modal (pure CSS/JS, no Bootstrap) -->
